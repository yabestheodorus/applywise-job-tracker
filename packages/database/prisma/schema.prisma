// ApplyWise — Prisma schema. See db-schema.md for the canonical spec.
// Multi-tenant: every top-level model carries `userId` (Supabase auth user UUID).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id              String           @id @default(cuid())
  userId          String // Supabase auth user UUID — owner of this row
  company         String
  role            String
  source          Source           @default(OTHER)
  rawText         String
  statusId        String
  status          StatusStage      @relation(fields: [statusId], references: [id])
  statusHistory   StatusEvent[]
  scheduledEvents ScheduledEvent[]
  interviewSessions InterviewSession[]
  // Job facts (AI-extracted from rawText)
  location        String? // e.g. "South Jakarta, Indonesia"
  workArrangement WorkArrangement?
  employmentType  EmploymentType?
  seniority       String? // e.g. "Mid-Senior", "Junior" — free-text, postings vary
  industry        String?
  jobUrl          String? // link back to the posting / company site
  summary         String? // AI 1–2 sentence role/company summary
  salaryExpected  Int?
  salaryOffered   Int?
  requirements    String[] // requirement/qualification bullets (full phrases)
  skills          String[] // explicit required skills/tech, e.g. ["React", "Node.js"]
  matchedSkills   String[] // computed: skills ∩ UserProfile.skills (empty until a profile exists)
  gapSkills       String[] // computed: skills not in UserProfile.skills
  matchScore      Int? // AI job-match score 0–100 (Groq), set on creation (if a profile exists) or recalculated
  matchRationale  String? // short AI explanation behind matchScore/matchedSkills/gapSkills
  appliedDate     DateTime         @default(now())
  followUpDate    DateTime?
  deadlineDate    DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([statusId])
}

// User-defined, fully dynamic — not a fixed enum.
// Seeded with sensible defaults on first sign-in, then editable.
model StatusStage {
  id           String        @id @default(cuid())
  userId       String // stages are per-user
  label        String
  order        Int // controls column position on the Kanban board
  color        String        @default("#94a3b8") // hex
  isTerminal   Boolean       @default(false)
  applications Application[]
  statusEvents StatusEvent[]
  createdAt    DateTime      @default(now())

  @@index([userId])
}

// Tracks every status change over time (powers the timeline).
model StatusEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  statusId      String
  status        StatusStage @relation(fields: [statusId], references: [id])
  note          String? // short one-line summary for the timeline row
  rawText       String? // the pasted update message, cleaned + markdown-formatted by the LLM
  occurredAt    DateTime    @default(now())

  @@index([applicationId])
}

// A time-flagged item captured from a status update (or added manually):
// an interview slot, an assessment deadline, a follow-up reminder. Powers the
// "Upcoming" agenda — listed across all applications, sorted by scheduledAt.
model ScheduledEvent {
  id            String             @id @default(cuid())
  userId        String // owner (Supabase auth UUID) — enables cross-application querying
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title         String // e.g. "Technical interview", "Take-home assessment due"
  type          ScheduledEventType @default(OTHER)
  scheduledAt   DateTime // exact moment (date + time) the event is due/happens
  note          String?
  completed     Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId, scheduledAt])
  @@index([applicationId])
}

enum ScheduledEventType {
  INTERVIEW
  ASSESSMENT
  DEADLINE
  FOLLOWUP
  OTHER
}

enum Source {
  WHATSAPP
  EMAIL
  LINKEDIN
  GLINTS
  JOBSTREET
  DIRECT
  OTHER
}

enum WorkArrangement {
  REMOTE
  HYBRID
  ONSITE
}

enum EmploymentType {
  FULLTIME
  PARTTIME
  CONTRACT
  INTERNSHIP
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique // one profile per Supabase auth user

  // Identity / contact
  fullName String?
  headline String?
  email    String?
  phone    String?
  location String?
  summary  String?
  links    Json? // { linkedin, github, portfolio, website }

  // Skills & matching
  skills          String[]
  yearsExperience Int?

  // Structured CV content
  experiences    WorkExperience[]
  education      Education[]
  certifications String[]
  languages      String[]

  // CV source artifacts
  cvFileUrl     String?
  cvFileName    String?
  cvRawText     String?
  cvUploadedAt  DateTime?
  cvParseStatus CvParseStatus @default(NONE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Reusable answers to common application questions. The user pastes a
// filled-in application form; the AI extracts question→answer pairs and either
// creates a new Template or updates the existing one covering the same topic
// (so similar questions don't pile up duplicates). Copy-to-clipboard when
// filling out the next application.
model Template {
  id        String   @id @default(cuid())
  userId    String // owner (Supabase auth UUID)
  topic     String   @default("Others") // short 1–2 word grouping label, e.g. "Salary", "Experience"
  question  String // the application question, normalised, e.g. "Why do you want to work here?"
  answer    String // the user's reusable answer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum CvParseStatus {
  NONE
  PROCESSING
  COMPLETED
  FAILED
}

// One row per job/role on the CV. AI-extracted, then user-editable.
model WorkExperience {
  id          String      @id @default(cuid())
  profileId   String
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  title       String
  location    String?
  startDate   String? // CVs are inconsistent — kept as string
  endDate     String?
  isCurrent   Boolean     @default(false)
  description String?
  skillsUsed  String[]
  order       Int         @default(0)

  @@index([profileId])
}

// AI-driven interview prep tied to ONE Application. Generates tailored questions
// from the job + the user's profile, coaches typed answers, and distils each into
// memorable key points the user drills until the answers are "loaded". See
// Product.md → "Interview Training Session" and agents.md.
model InterviewSession {
  id             String                 @id @default(cuid())
  userId         String // owner (Supabase auth UUID)
  applicationId  String
  application    Application            @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status         InterviewSessionStatus @default(IN_PROGRESS)
  readinessScore Int? // 0–100, computed from practiced + self-rated questions
  questions      InterviewQuestion[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([userId])
  @@index([applicationId])
}

// One generated question within a session, plus its practice state.
model InterviewQuestion {
  id              String                    @id @default(cuid())
  userId          String
  sessionId       String
  session         InterviewSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order           Int
  category        InterviewQuestionCategory @default(BEHAVIORAL)
  question        String
  rationale       String? // why this is likely to be asked
  talkingPoints   String[] // AI-seeded hints (from the user's real experience) to shape an answer
  // Practice state (filled in as the user works through the session)
  userAnswer      String? // the user's own attempt
  feedback        String? // AI coaching on the attempt
  improvedAnswer  String? // AI's improved version
  keyPoints       String[] // 3–5 memorable bullets to drill
  score           Int? // 1–5 rubric score from coaching
  selfRating      Int? // 1–5 self-rating from the flashcard drill
  practiceStatus  InterviewPracticeStatus   @default(NOT_STARTED)
  savedTemplateId String? // set when the polished answer was saved to the Template library
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([sessionId])
  @@index([userId])
}

enum InterviewSessionStatus {
  GENERATING
  IN_PROGRESS
  COMPLETED
}

enum InterviewQuestionCategory {
  BEHAVIORAL
  TECHNICAL
  ROLE_FIT
  COMPANY
  GAP
  LOGISTICS
}

enum InterviewPracticeStatus {
  NOT_STARTED
  ANSWERED
  REVIEWED
}

// One row per degree/program. AI-extracted, user-editable.
model Education {
  id           String      @id @default(cuid())
  profileId    String
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution  String
  degree       String?
  fieldOfStudy String?
  startDate    String?
  endDate      String?
  description  String?
  order        Int         @default(0)

  @@index([profileId])
}

// A self-assessment of ONE profile skill: a short scenario-based multiple-choice
// technical test, AI-generated and calibrated to the user's experience, scored
// deterministically into a proficiency level. Not tied to any Application —
// purely "how good am I at this skill?". See Product.md → "Skills Assessment".
model SkillAssessment {
  id            String               @id @default(cuid())
  userId        String // owner (Supabase auth UUID)
  skill         String // the profile skill under test, e.g. "PostgreSQL"
  status        AssessmentStatus     @default(GENERATING)
  questionCount Int                  @default(0)
  correctCount  Int? // filled on submit
  scorePct      Int? // raw percent correct, 0–100
  level         ProficiencyLevel? // difficulty-weighted proficiency, derived on submit
  summary       String? // AI debrief: 1–2 sentence overview
  strengths     String[] // AI debrief: sub-topics the user is solid on
  focusAreas    String[] // AI debrief: sub-topics to study next
  questions     AssessmentQuestion[]
  createdAt     DateTime             @default(now())
  completedAt   DateTime?
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([userId, skill])
}

// One scenario-based MCQ within an assessment. Correct answer + explanation are
// withheld from the client until the assessment is submitted (graded server-side).
model AssessmentQuestion {
  id            String             @id @default(cuid())
  assessmentId  String
  assessment    SkillAssessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  userId        String
  order         Int
  difficulty    QuestionDifficulty @default(MID)
  subtopic      String? // short label for the area tested, e.g. "Indexing"
  scenario      String // the real-world situation set-up
  prompt        String // the actual question being asked
  options       String[] // exactly 4 answer choices
  correctIndex  Int // 0-based index of the correct option
  explanation   String // why the correct option is right
  selectedIndex Int? // the user's choice (filled on submit)
  isCorrect     Boolean? // selectedIndex === correctIndex (filled on submit)
  createdAt     DateTime           @default(now())

  @@index([assessmentId])
  @@index([userId])
}

enum AssessmentStatus {
  GENERATING
  IN_PROGRESS
  COMPLETED
}

enum QuestionDifficulty {
  JUNIOR
  MID
  SENIOR
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}
